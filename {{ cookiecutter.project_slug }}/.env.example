# Django
DJANGO_SETTINGS_MODULE={{ cookiecutter.project_slug }}.settings.local
DJANGO_SECRET_KEY=change_me_in_production

# Database
POSTGRES_DB={{ cookiecutter.postgresql_db }}
POSTGRES_USER={{ cookiecutter.postgresql_user }}
POSTGRES_PASSWORD={{ cookiecutter.postgresql_password }}
POSTGRES_HOST=db
POSTGRES_PORT=5432

{% if cookiecutter.use_celery == 'y' %}
# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
{% endif %}

# Cache
CACHE_URL=redis://redis:6379/2

{% if cookiecutter.include_oauth2 == 'y' %}
# OAuth2 - Google
GOOGLE_OAUTH2_CLIENT_ID=
GOOGLE_OAUTH2_CLIENT_SECRET=

# OAuth2 - GitHub
GITHUB_OAUTH2_CLIENT_ID=
GITHUB_OAUTH2_CLIENT_SECRET=

# OAuth2 - Facebook
FACEBOOK_OAUTH2_CLIENT_ID=
FACEBOOK_OAUTH2_CLIENT_SECRET=
{% endif %}

{% if cookiecutter.include_sentry == 'y' %}
# Sentry
SENTRY_DSN=
{% endif %}
